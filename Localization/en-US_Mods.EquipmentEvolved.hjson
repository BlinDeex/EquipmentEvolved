Configs: {
	PrefixConfig: {
		DisplayName: Equipment Evolved Configuration

		Headers: {
			CoreSystems: "[c/ff8888:Core Systems]"
			EquipmentTypes: "[c/88ff88:Equipment Types]"
			Advanced: "[c/8888ff:Advanced Settings]"
		}

		EnableCharms: {
			Label: Enable Charms System
			Tooltip: Toggles the entire Charms drop and application system. If disabled, enemies will no longer drop charms.
		}

		EnableModdedReforges: {
			Label: Enable Custom Reforges
			Tooltip: Enables all the unique, mechanic-altering weapon reforges introduced by this mod.
		}

		EnableArmorReforging: {
			Label: Enable Armor Reforging
			Tooltip: Allows armor pieces to be reforged with powerful universal and specialized traits.
		}

		EnableToolReforging: {
			Label: Enable Tool Reforging
			Tooltip: Allows pickaxes, axes, and hammers to roll unique utility prefixes.
		}

		EnableExperimentalReforges: {
			Label: Enable Experimental Reforges
			Tooltip: Enables work-in-progress or highly volatile reforges. Balance is not guaranteed!
		}

		EnableVanillaReforges: {
			Label: Enable Vanilla Reforges
			Tooltip: If enabled, vanilla modifiers (like 'Legendary' or 'Warding') will remain in the Goblin Tinkerer's pool.
		}

		EnableEnvironmentalCharmDrops: {
			Label: Enable Environmental Charm Drops
			Tooltip: If enabled, enemies killed by environmental factors (lava, traps, fall damage, town NPCs) will drop charms and increase pity for the closest player.
		}

		EnableOtherModPrefixes: {
			Label: Enable Other Mod Prefixes
			Tooltip: If enabled, allows items to roll custom prefixes added by other mods like Calamity 'Serrated'
		}
	}
}

UI: {
	ConverterNotice: {
		Line1: Your inventory is getting cluttered with Charms!
		Line2: Craft a [c/00FFFF:Charm Converter] to automatically scrap them into dust.
		Line3: Recipe: 5 Gold/Platinum Bars + 10 Wire at an Anvil.
	}
}

