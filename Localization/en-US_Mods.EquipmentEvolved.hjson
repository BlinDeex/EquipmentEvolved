			DisplayName: Phantom
			SetBonus:
				'''
				SET BONUS [Active]: Calls forth {0} identical clones capable of repeating all your actions for as long as they
				are active, clones require tremendous focus to maintain hence apply these debuffs for as long as they are active:
				Voidseal: Completely stops all health and mana regeneration, health and mana potions cannot be consumed
				Soulburn: Deals damage over time and impairs vision, grows more intense the longer it lasts
				'''
			Description: "{0}% Increased all true damage"
		}

		Phalanx: {
			DisplayName: Phalanx
			SetBonus:
				'''
				SET BONUS [Passive]: Reactive armor plating, detects powerful projectiles around you and shoots piece of itself
