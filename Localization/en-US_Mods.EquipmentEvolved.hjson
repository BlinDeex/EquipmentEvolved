				'''
			Description: "{0}% Increased movement speed"
		}

		Augmented: {
			DisplayName: Augmented
			Description: You gain buffs for each armor piece equipped, scales with defense:
			SetBonus: SET BONUS [Passive]: Damage is increased by {0}% for each buff active
			LevelLine: "{0} Defense > Gain {1}"
		}

		Inevitable: {
			DisplayName: Inevitable
			SetBonus:
				'''
				SET BONUS [Active]: Summons a doomsday clock that tolls for {0} seconds. 
